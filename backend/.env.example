# Salin ke .env: cp .env.example .env
# Lihat apps/docs/SETUP.md — jalankan perintah make dari folder apps/

# Environment: development | production
ENVIRONMENT=development

# HTTP server (default 8080)
PORT=8080

# PostgreSQL — user audi, database learn_platform (aplikasi)
# Shell admin: psql -U audi -d postgres   atau: cd apps && make db-psql
# Shell app DB: psql -U audi -d learn_platform
DATABASE_URL=postgres://audi:090393@localhost:5432/learn_platform?sslmode=disable

# Wajib diganti di production
JWT_SECRET=your-secret-key-change-in-production

# Origin frontend untuk CORS (Vite dev server)
CORS_ORIGIN=http://localhost:3000
